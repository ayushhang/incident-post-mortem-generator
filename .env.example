# Application
NODE_ENV=development
APP_NAME=Incident Post-Mortem Generator
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
API_PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/incident_postmortem

# Redis / Queue
REDIS_URL=redis://localhost:6379

# Authentication
AUTH_SECRET=your-super-secret-key-change-in-production
AUTH_URL=http://localhost:3000/api/auth
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_NAME=next-auth.session-token
NEXTAUTH_URL=http://localhost:3000

# LLM Providers
LLM_PROVIDER=openai
LLM_MODEL_PRIMARY=gpt-4o
LLM_MODEL_FALLBACK=gpt-4o-mini
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_AI_API_KEY=your-key-here
OPENROUTER_API_KEY=your-key-here

# File Storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=incident-postmortem
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/incident-postmortem

# PDF / Export
PDF_SERVICE_URL=http://localhost:3002

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_DEFAULT_CHANNEL=C00000000

# Email / Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@incident-postmortem.com

# Observability
LOG_LEVEL=debug
SENTRY_DSN=https://your-sentry-dsn
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Feature Flags
ENABLE_SLACK_NOTIFICATIONS=true
ENABLE_SIMILARITY_DETECTION=true
ENABLE_PATTERN_ANALYTICS=true
ENABLE_MULTI_TENANCY=false
